# ==============================================================================
# PeopleVision AI Environment Variables Configuration
# ==============================================================================

# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# ------------------------------------------------------------------------------
# Database Settings
# ------------------------------------------------------------------------------
# PostgreSQL URL format: postgresql://username:password@host:port/database_name
# For local run with Docker Compose, 'db' is the hostname of the postgres container.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/peoplevision
# If you want to use SQLite locally for testing without Postgres:
# DATABASE_URL=sqlite:///./peoplevision.db

# ------------------------------------------------------------------------------
# Camera / Video Settings
# ------------------------------------------------------------------------------
# Camera source can be:
# - USB Camera Index (e.g., 0, 1)
# - RTSP Stream URL (e.g., rtsp://username:password@ip:port/h264)
# - Local video file path (e.g., data/test_video.mp4)
CAMERA_SOURCE=1

# Flag to specify if the camera source is a static video file.
# If true, the reader will loop the video indefinitely to simulate a camera feed.
IS_VIDEO_FILE=false

# ------------------------------------------------------------------------------
# YOLO Detector Settings
# ------------------------------------------------------------------------------
# YOLO model variant (yolov8n.pt, yolov8m.pt, yolov8x.pt, yolov11n.pt, etc.)
# The model will download automatically on first run.
YOLO_MODEL=yolov8n.pt

# Confidence threshold for person detection (0.0 to 1.0)
CONFIDENCE_THRESHOLD=0.4

# Target class ID for detection (COCO class ID 0 is 'person')
TARGET_CLASS_ID=0

# Device selection (cpu, cuda, or mps)
DEVICE=cpu

# ------------------------------------------------------------------------------
# ByteTrack Settings
# ------------------------------------------------------------------------------
# Frame rate of the tracker (affects tracking persistence calculations)
TRACKER_FPS=30

# Buffer length for lost tracks
TRACK_BUFFER=30

# ------------------------------------------------------------------------------
# Line Counter Coordinates (Relative Percentages)
# ------------------------------------------------------------------------------
# Coordinates of the virtual counting line, expressed as percentages of the frame size.
# By default, a horizontal line in the middle of the frame:
# Start: (0%, 50%) -> End: (100%, 50%)
LINE_START_X_PCT=0.0
LINE_START_Y_PCT=0.5
LINE_END_X_PCT=1.0
LINE_END_Y_PCT=0.5

# ------------------------------------------------------------------------------
# Server / API Settings
# ------------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_URL=http://localhost:8000
